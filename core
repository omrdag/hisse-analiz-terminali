
"""yfinance üzerinden fiyat geçmişi, temel veri ve haber çekme."""
from __future__ import annotations

import logging
from dataclasses import dataclass, field
from datetime import datetime, timezone

import pandas as pd
import yfinance as yf

logger = logging.getLogger(__name__)


@dataclass
class StockSnapshot:
    ticker: str
    ok: bool
    error: str | None = None
    name: str | None = None
    sector: str | None = None
    price: float | None = None
    history: pd.DataFrame | None = None
    info: dict = field(default_factory=dict)
    news: list = field(default_factory=list)
    earnings_date: datetime | None = None


def fetch_stock_snapshot(ticker: str, period: str = "1y") -> StockSnapshot:
    """Tek bir hisse için fiyat geçmişi + temel bilgileri çeker.
    Ağ/veri hatalarında uygulamayı çökertmeden ok=False ile döner."""
    try:
        tk = yf.Ticker(ticker)
        hist = tk.history(period=period, interval="1d", auto_adjust=True)
        if hist is None or hist.empty:
            return StockSnapshot(ticker=ticker, ok=False, error="Fiyat geçmişi bulunamadı")

        try:
            info = tk.get_info()
        except Exception:  # noqa: BLE001
            info = getattr(tk, "info", {}) or {}

        try:
            news = tk.news or []
        except Exception:  # noqa: BLE001
            news = []

        earnings_date = None
        try:
            cal = tk.get_earnings_dates(limit=4)
            if cal is not None and not cal.empty:
                now = datetime.now(timezone.utc)
                future = [d for d in cal.index if d.to_pydatetime() >= now]
                if future:
                    earnings_date = min(future).to_pydatetime()
        except Exception:  # noqa: BLE001
            pass

        last_price = float(hist["Close"].iloc[-1])

        return StockSnapshot(
            ticker=ticker,
            ok=True,
            name=info.get("shortName") or info.get("longName") or ticker,
            sector=info.get("sector"),
            price=last_price,
            history=hist,
            info=info,
            news=news,
            earnings_date=earnings_date,
        )
    except Exception as exc:  # noqa: BLE001
        logger.exception("Veri çekme hatası: %s", ticker)
        return StockSnapshot(ticker=ticker, ok=False, error=str(exc))


def fetch_many(tickers: list[str], period: str = "1y") -> dict[str, StockSnapshot]:
    return {t: fetch_stock_snapshot(t, period=period) for t in tickers}

"""Teknik gösterge hesaplamaları (RSI, EMA, SMA, hacim gücü, destek/direnç seviyeleri)."""
from __future__ import annotations

import numpy as np
import pandas as pd


def calculate_rsi(close: pd.Series, period: int = 14) -> pd.Series:
    """Standart 14 periyotluk RSI (Wilder yöntemi)."""
    delta = close.diff()
    gain = delta.where(delta > 0, 0.0)
    loss = -delta.where(delta < 0, 0.0)
    avg_gain = gain.ewm(alpha=1 / period, min_periods=period, adjust=False).mean()
    avg_loss = loss.ewm(alpha=1 / period, min_periods=period, adjust=False).mean()
    rs = avg_gain / avg_loss.replace(0, np.nan)
    rsi = 100 - (100 / (1 + rs))
    return rsi.fillna(50)


def calculate_ema(close: pd.Series, period: int) -> pd.Series:
    return close.ewm(span=period, adjust=False).mean()


def calculate_sma(close: pd.Series, period: int) -> pd.Series:
    return close.rolling(window=period, min_periods=max(1, period // 2)).mean()


def volume_strength(volume: pd.Series, lookback: int = 20) -> float:
    """Son işlem gününün hacmini, önceki ortalama hacme oranlar.
    1.0 = ortalama hacim, >1.2 güçlü hacim kabul edilir."""
    if len(volume) < 2:
        return 1.0
    lookback = min(lookback, len(volume) - 1)
    avg_vol = volume.iloc[-(lookback + 1):-1].mean()
    last_vol = volume.iloc[-1]
    if not avg_vol or pd.isna(avg_vol) or avg_vol == 0:
        return 1.0
    return float(last_vol / avg_vol)


def support_levels(close: pd.Series, windows: tuple[int, int, int] = (10, 30, 90)) -> dict:
    """Belirtilen pencerelerdeki en düşük kapanışları kademeli destek seviyesi olarak kullanır."""
    levels = {}
    for i, w in enumerate(windows, start=1):
        w = min(w, len(close))
        levels[f"support_{i}"] = float(close.tail(w).min())
    return levels


def resistance_levels(close: pd.Series, windows: tuple[int, int, int] = (10, 30, 90)) -> dict:
    """Belirtilen pencerelerdeki en yüksek kapanışları direnç seviyesi olarak kullanır."""
    levels = {}
    for i, w in enumerate(windows, start=1):
        w = min(w, len(close))
        levels[f"resistance_{i}"] = float(close.tail(w).max())
    return levels

"""Alım bölgeleri, stop-loss/hedefler, durum etiketleri ve karar üretimi."""
from __future__ import annotations

from dataclasses import dataclass, field
from datetime import datetime, timedelta

import pandas as pd

from .indicators import resistance_levels, support_levels

BUY_ZONE_BAND_PCT = 2.0  # her destek seviyesi etrafında ± bant
NEAR_ZONE_TOLERANCE_PCT = 3.0  # "alım bölgesine yakın" sayılma eşiği
MIN_RISK_REWARD = 2.0
RAPID_PUMP_THRESHOLD_PCT = 18.0  # 5 günde bu kadar artış FOMO sayılır
EARNINGS_RISK_DAYS = 7


@dataclass
class BuyZone:
    low: float
    high: float

    def __str__(self) -> str:  # noqa: D105
        return f"{self.low:.2f}-{self.high:.2f}"

    @property
    def mid(self) -> float:
        return (self.low + self.high) / 2


def build_buy_zones(close_series: pd.Series) -> tuple[BuyZone, BuyZone, BuyZone]:
    """Son 10/30/90 günlük destekleri kademeli alım bölgesine çevirir (±%2 bant)."""
    levels = support_levels(close_series, windows=(10, 30, 90))
    ordered = sorted([levels["support_1"], levels["support_2"], levels["support_3"]], reverse=True)
    s1, s2, s3 = ordered

    def band(level: float) -> BuyZone:
        half = level * (BUY_ZONE_BAND_PCT / 100)
        return BuyZone(low=round(level - half, 2), high=round(level + half, 2))

    return band(s1), band(s2), band(s3)


def compute_stop_and_targets(
    close_series: pd.Series, zone1: BuyZone, zone3: BuyZone
) -> tuple[float, float, float, float]:
    """Giriş referansı = 1. alım bölgesi ortası. Stop-loss = en derin destek bandının altı.
    Hedefler gerçek direnç seviyelerinden (son 20/60/252 günlük tepe) türetilir, böylece
    Risk/Ödül gerçekten değişken bir değerdir (sabit 1:2 değil) ve filtre anlamlı çalışır."""
    entry = zone1.mid
    stop_loss = round(zone3.low * 0.97, 2)
    risk = max(entry - stop_loss, entry * 0.01)

    res = resistance_levels(close_series, windows=(20, 60, 252))
    target_1 = round(max(res["resistance_1"], entry * 1.03), 2)
    target_2 = round(max(res["resistance_2"], res["resistance_3"], target_1 * 1.05), 2)

    risk_reward = round((target_1 - entry) / risk, 2) if risk else 0.0
    return stop_loss, target_1, target_2, risk_reward


def distance_to_nearest_zone_pct(price: float, zone1: BuyZone) -> float:
    """Fiyatın 1. alım bölgesine yüzde uzaklığı (bölge içindeyse 0)."""
    if zone1.low <= price <= zone1.high:
        return 0.0
    if price > zone1.high:
        return round((price - zone1.high) / price * 100, 2)
    return round((zone1.low - price) / price * 100, 2)


def news_catalyst_score(news_items: list, lookback_days: int = 7) -> float:
    """Basit haber/katalizör skoru: yakın zamanlı haber yoğunluğuna dayalı kaba bir gösterge.
    Not: Gerçek duygu analizi için ileride bir NLP/LLM entegrasyonu eklenebilir (bkz. README)."""
    if not news_items:
        return 50.0
    cutoff = datetime.utcnow() - timedelta(days=lookback_days)
    recent = 0
    for item in news_items:
        ts = item.get("providerPublishTime")
        if ts:
            try:
                dt = datetime.utcfromtimestamp(ts)
                if dt >= cutoff:
                    recent += 1
            except Exception:  # noqa: BLE001
                continue
    if recent >= 5:
        return 85.0
    if recent >= 2:
        return 65.0
    if recent >= 1:
        return 55.0
    return 45.0


def decide_label(score: float) -> str:
    if score >= 85:
        return "Güçlü AL"
    if score >= 75:
        return "AL"
    if score >= 65:
        return "Kademeli AL"
    if score >= 55:
        return "BEKLE"
    return "Uzak Dur"


def determine_status_tags(
    *,
    price: float,
    rsi: float,
    zone1: BuyZone,
    distance_pct: float,
    risk_reward: float,
    pct_change_5d: float,
    earnings_soon: bool,
    criteria_met: bool,
    was_opportunity_before: bool,
) -> list[str]:
    """Öncelik sırasına göre durum etiketlerini üretir (birden fazla etiket dönebilir)."""
    tags: list[str] = []

    if earnings_soon:
        tags.append("BİLANÇO RİSKİ")
    if pct_change_5d >= RAPID_PUMP_THRESHOLD_PCT:
        tags.append("FOMO RİSKİ")
    if rsi > 70:
        tags.append("GERİ ÇEKİLME BEKLE")
    if risk_reward < MIN_RISK_REWARD:
        tags.append("RİSK/ÖDÜL YETERSİZ")

    if zone1.low <= price <= zone1.high:
        tags.append("ALIM BÖLGESİNDE")
    elif distance_pct <= NEAR_ZONE_TOLERANCE_PCT:
        tags.append("ALIM BÖLGESİNE YAKIN")
    elif price > zone1.high:
        tags.append("DİRENÇ KIRILIMI BEKLE")

    if criteria_met:
        tags.append("KRİTERLER TAMAMLANDI")
    elif was_opportunity_before:
        tags.append("KRİTERLER BOZULDU")

    return tags or ["BEKLE"]

"""Tarama sonuçlarının CSV dosyalarına kaydedilmesi/okunması."""
from __future__ import annotations

import os

import pandas as pd

DATA_DIR = "data"
OPPORTUNITIES_PATH = os.path.join(DATA_DIR, "opportunities.csv")
HISTORY_PATH = os.path.join(DATA_DIR, "opportunity_history.csv")
REMOVED_PATH = os.path.join(DATA_DIR, "removed_opportunities.csv")
WAITING_PATH = os.path.join(DATA_DIR, "waiting_list.csv")

COLUMNS = [
    "scan_time", "ticker", "name", "sector", "vade", "rank_no", "total_score",
    "decision", "buy_zone_1", "buy_zone_2", "buy_zone_3", "stop_loss",
    "target_1", "target_2", "risk_reward", "status", "price",
    "rsi", "ema20", "sma50", "sma200", "distance_pct", "news_score",
    "rank_score", "meets_criteria",
]


def _ensure_dir() -> None:
    os.makedirs(DATA_DIR, exist_ok=True)


def save_opportunities(df: pd.DataFrame) -> None:
    _ensure_dir()
    df.to_csv(OPPORTUNITIES_PATH, index=False)


def load_opportunities() -> pd.DataFrame:
    if not os.path.exists(OPPORTUNITIES_PATH):
        return pd.DataFrame(columns=COLUMNS)
    return pd.read_csv(OPPORTUNITIES_PATH)


def save_waiting_list(df: pd.DataFrame) -> None:
    _ensure_dir()
    df.to_csv(WAITING_PATH, index=False)


def load_waiting_list() -> pd.DataFrame:
    if not os.path.exists(WAITING_PATH):
        return pd.DataFrame(columns=COLUMNS)
    return pd.read_csv(WAITING_PATH)


def append_history(df: pd.DataFrame) -> None:
    _ensure_dir()
    header = not os.path.exists(HISTORY_PATH)
    df.to_csv(HISTORY_PATH, mode="a", index=False, header=header)


def load_history() -> pd.DataFrame:
    if not os.path.exists(HISTORY_PATH):
        return pd.DataFrame(columns=COLUMNS)
    return pd.read_csv(HISTORY_PATH)


def append_removed(df: pd.DataFrame) -> None:
    _ensure_dir()
    header = not os.path.exists(REMOVED_PATH)
    df.to_csv(REMOVED_PATH, mode="a", index=False, header=header)


def load_removed() -> pd.DataFrame:
    if not os.path.exists(REMOVED_PATH):
        return pd.DataFrame(columns=COLUMNS)
    return pd.read_csv(REMOVED_PATH)


def last_scan_time() -> str | None:
    df = load_opportunities()
    if df.empty or "scan_time" not in df.columns:
        df = load_waiting_list()
    if df.empty or "scan_time" not in df.columns:
        return None
    return str(df["scan_time"].iloc[0])

"""Fırsat Sıralama Skoru: toplam skor, alım bölgesi yakınlığı, risk/ödül ve haber etkisini birleştirir.

Fırsat Sıralama Skoru = Toplam Skor x 0.45
                       + Alım Bölgesine Yakınlık Skoru x 0.25
                       + Risk/Ödül Skoru x 0.20
                       + Haber/Katalizör Skoru x 0.10
"""
from __future__ import annotations


def proximity_score(distance_pct: float) -> float:
    """Fiyat bölge içindeyse 100; uzaklaştıkça düşer, %20 ve üzerinde 0'a yaklaşır."""
    return round(max(0.0, 100 - min(distance_pct, 20) * 5), 1)


def risk_reward_score(rr: float) -> float:
    """RR=4 ve üzeri 100 puan; RR arttıkça doğrusal artar, düştükçe azalır."""
    return round(min(100.0, max(0.0, (rr / 4.0) * 100)), 1)


def opportunity_rank_score(
    total_score: float,
    distance_pct: float,
    risk_reward: float,
    news_score: float,
) -> float:
    prox = proximity_score(distance_pct)
    rr_score = risk_reward_score(risk_reward)
    return round(total_score * 0.45 + prox * 0.25 + rr_score * 0.20 + news_score * 0.10, 2)

"""Watchlist'i tarayıp fırsatları / bekleme listesini / bozulan kriterleri üreten ana motor."""
from __future__ import annotations

from datetime import datetime, timezone

import pandas as pd

from . import persistence
from .data_fetcher import fetch_stock_snapshot
from .opportunity_engine import (
    EARNINGS_RISK_DAYS,
    MIN_RISK_REWARD,
    NEAR_ZONE_TOLERANCE_PCT,
    build_buy_zones,
    compute_stop_and_targets,
    decide_label,
    determine_status_tags,
    distance_to_nearest_zone_pct,
    news_catalyst_score,
)
from .ranking import opportunity_rank_score
from .scoring import (
    compute_fundamental_snapshot,
    compute_technical_snapshot,
    fundamental_score,
    long_term_score,
    medium_term_score,
    short_term_score,
    technical_score,
)

VADE_CONFIG = {
    "kisa": {"label": "Kısa", "threshold": 65, "score_key": "short_score"},
    "orta": {"label": "Orta", "threshold": 70, "score_key": "medium_score"},
    "uzun": {"label": "Uzun", "threshold": 75, "score_key": "long_score"},
}


def _row_for_vade(base: dict, vade_key: str) -> dict:
    cfg = VADE_CONFIG[vade_key]
    score = base[cfg["score_key"]]
    row = dict(base)
    row["vade"] = cfg["label"]
    row["total_score"] = score
    row["decision"] = decide_label(score)
    return row


def run_scan(tickers: list[str]) -> dict:
    """Watchlist'i tarar; opportunities/watchlist(bekleme)/removed DataFrame'lerini
    döner ve ilgili CSV dosyalarına yazar."""
    scan_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    previous = persistence.load_opportunities()
    previous_tickers = set(previous["ticker"].tolist()) if not previous.empty else set()

    all_rows: list[dict] = []
    failed: list[dict] = []

    for ticker in tickers:
        snap = fetch_stock_snapshot(ticker)
        if not snap.ok or snap.history is None or len(snap.history) < 30:
            failed.append({"ticker": ticker, "error": snap.error or "Yetersiz veri"})
            continue

        tech = compute_technical_snapshot(snap.history)
        fund = compute_fundamental_snapshot(snap.info)

        t_score = technical_score(tech)
        f_score = fundamental_score(fund)

        short_s = short_term_score(t_score)
        medium_s = medium_term_score(t_score, f_score)
        long_s = long_term_score(t_score, f_score)

        zone1, zone2, zone3 = build_buy_zones(snap.history["Close"])
        stop_loss, target_1, target_2, rr = compute_stop_and_targets(snap.history["Close"], zone1, zone3)
        distance_pct = distance_to_nearest_zone_pct(tech.price, zone1)
        news_score = news_catalyst_score(snap.news)

        earnings_soon = False
        if snap.earnings_date:
            days_to_earnings = (snap.earnings_date - datetime.now(timezone.utc)).days
            earnings_soon = 0 <= days_to_earnings <= EARNINGS_RISK_DAYS

        base = {
            "scan_time": scan_time,
            "ticker": ticker,
            "name": snap.name or ticker,
            "sector": fund.sector,
            "price": round(tech.price, 2),
            "rsi": round(tech.rsi, 1),
            "ema20": round(tech.ema20, 2),
            "sma50": round(tech.sma50, 2),
            "sma200": round(tech.sma200, 2),
            "buy_zone_1": str(zone1),
            "buy_zone_2": str(zone2),
            "buy_zone_3": str(zone3),
            "stop_loss": stop_loss,
            "target_1": target_1,
            "target_2": target_2,
            "risk_reward": rr,
            "distance_pct": distance_pct,
            "news_score": news_score,
            "short_score": short_s,
            "medium_score": medium_s,
            "long_score": long_s,
        }

        for vade_key in VADE_CONFIG:
            cfg = VADE_CONFIG[vade_key]
            score = base[cfg["score_key"]]
            criteria_met = (
                score >= cfg["threshold"]
                and distance_pct <= NEAR_ZONE_TOLERANCE_PCT
                and rr >= MIN_RISK_REWARD
            )
            was_before = ticker in previous_tickers

            tags = determine_status_tags(
                price=tech.price,
                rsi=tech.rsi,
                zone1=zone1,
                distance_pct=distance_pct,
                risk_reward=rr,
                pct_change_5d=tech.pct_change_5d,
                earnings_soon=earnings_soon,
                criteria_met=criteria_met,
                was_opportunity_before=was_before,
            )

            row = _row_for_vade(base, vade_key)
            row["status"] = " | ".join(tags)
            row["meets_criteria"] = criteria_met
            row["rank_score"] = opportunity_rank_score(score, distance_pct, rr, news_score)
            all_rows.append(row)

    full_df = pd.DataFrame(all_rows)
    empty = pd.DataFrame(columns=persistence.COLUMNS)
    if full_df.empty:
        persistence.save_opportunities(empty)
        persistence.save_waiting_list(empty)
        return {"opportunities": empty, "watchlist": empty, "removed": empty, "failed": failed}

    opportunities_df = full_df[full_df["meets_criteria"]].copy()
    watchlist_df = full_df[~full_df["meets_criteria"]].copy()

    # KRİTERLER BOZULDU: önceki taramada fırsat olup şimdi olmayan hisseler
    removed_df = full_df[
        full_df["ticker"].isin(previous_tickers) & (~full_df["meets_criteria"])
    ].copy()

    for part in (opportunities_df, watchlist_df):
        part.sort_values("rank_score", ascending=False, inplace=True)
        part.reset_index(drop=True, inplace=True)
        part["rank_no"] = part.index + 1

    persistence.save_opportunities(opportunities_df)
    persistence.save_waiting_list(watchlist_df)
    persistence.append_history(full_df)
    if not removed_df.empty:
        persistence.append_removed(removed_df)

    return {
        "opportunities": opportunities_df,
        "watchlist": watchlist_df,
        "removed": removed_df,
        "failed": failed,
    }

"""Teknik ve temel skor hesaplama mantığı + vadeye göre birleşik skorlar."""
from __future__ import annotations

from dataclasses import dataclass

import pandas as pd

from .indicators import calculate_ema, calculate_rsi, calculate_sma, volume_strength


@dataclass
class TechnicalSnapshot:
    price: float
    rsi: float
    ema20: float
    sma50: float
    sma200: float
    vol_strength: float
    pct_change_5d: float
    pct_change_20d: float


def compute_technical_snapshot(hist: pd.DataFrame) -> TechnicalSnapshot:
    close = hist["Close"]
    rsi = calculate_rsi(close).iloc[-1]
    ema20 = calculate_ema(close, 20).iloc[-1]
    sma50 = calculate_sma(close, 50).iloc[-1]
    sma200 = calculate_sma(close, 200).iloc[-1]
    vol_str = volume_strength(hist["Volume"])
    price = float(close.iloc[-1])

    def pct_change(n: int) -> float:
        if len(close) <= n:
            return 0.0
        prev = close.iloc[-n - 1]
        if not prev:
            return 0.0
        return float((price - prev) / prev * 100)

    return TechnicalSnapshot(
        price=price,
        rsi=float(rsi) if pd.notna(rsi) else 50.0,
        ema20=float(ema20) if pd.notna(ema20) else price,
        sma50=float(sma50) if pd.notna(sma50) else price,
        sma200=float(sma200) if pd.notna(sma200) else price,
        vol_strength=float(vol_str),
        pct_change_5d=pct_change(5),
        pct_change_20d=pct_change(20),
    )


def technical_score(t: TechnicalSnapshot) -> float:
    """0-100 arası teknik skor. RSI bölgesi (35p) + trend/MA üzeri konum (45p) + hacim (20p)."""
    score = 0.0

    if 45 <= t.rsi <= 65:
        score += 35
    elif 35 <= t.rsi < 45 or 65 < t.rsi <= 72:
        score += 22
    elif t.rsi > 72:
        score += 8  # aşırı alım
    else:
        score += 15  # aşırı satım, dipten dönüş ihtimali

    trend_points = 0.0
    if t.price >= t.ema20:
        trend_points += 15
    if t.price >= t.sma50:
        trend_points += 15
    if t.price >= t.sma200:
        trend_points += 15
    score += trend_points

    if t.vol_strength >= 1.5:
        score += 20
    elif t.vol_strength >= 1.1:
        score += 14
    elif t.vol_strength >= 0.8:
        score += 8
    else:
        score += 3

    return round(min(100.0, max(0.0, score)), 1)


@dataclass
class FundamentalSnapshot:
    pe: float | None
    forward_pe: float | None
    profit_margin: float | None
    revenue_growth: float | None
    earnings_growth: float | None
    debt_to_equity: float | None
    current_ratio: float | None
    roe: float | None
    sector: str | None
    market_cap: float | None


def compute_fundamental_snapshot(info: dict) -> FundamentalSnapshot:
    return FundamentalSnapshot(
        pe=info.get("trailingPE"),
        forward_pe=info.get("forwardPE"),
        profit_margin=info.get("profitMargins"),
        revenue_growth=info.get("revenueGrowth"),
        earnings_growth=info.get("earningsGrowth"),
        debt_to_equity=info.get("debtToEquity"),
        current_ratio=info.get("currentRatio"),
        roe=info.get("returnOnEquity"),
        sector=info.get("sector"),
        market_cap=info.get("marketCap"),
    )


def fundamental_score(f: FundamentalSnapshot) -> float:
    """0-100 arası temel skor: kârlılık (25p) + gelir büyümesi (25p) + borç yönetimi (20p)
    + ROE (15p) + değerleme (15p). Veri eksikse o kalem için nötr puan verilir."""
    score = 0.0

    if f.profit_margin is not None:
        if f.profit_margin > 0.15:
            score += 25
        elif f.profit_margin > 0:
            score += 15
        elif f.profit_margin > -0.10:
            score += 6
    else:
        score += 10

    if f.revenue_growth is not None:
        if f.revenue_growth > 0.20:
            score += 25
        elif f.revenue_growth > 0.05:
            score += 18
        elif f.revenue_growth > 0:
            score += 10
        else:
            score += 2
    else:
        score += 10

    if f.debt_to_equity is not None:
        if f.debt_to_equity < 50:
            score += 20
        elif f.debt_to_equity < 100:
            score += 14
        elif f.debt_to_equity < 200:
            score += 7
        else:
            score += 2
    else:
        score += 10

    if f.roe is not None:
        if f.roe > 0.20:
            score += 15
        elif f.roe > 0.10:
            score += 10
        elif f.roe > 0:
            score += 5
    else:
        score += 7

    if f.pe is not None and f.pe > 0:
        if f.pe < 25:
            score += 15
        elif f.pe < 40:
            score += 10
        elif f.pe < 60:
            score += 5
        else:
            score += 1
    else:
        score += 7

    return round(min(100.0, max(0.0, score)), 1)


def short_term_score(tech: float) -> float:
    """Kısa vade: ağırlıklı olarak teknik görünüm."""
    return round(tech, 1)


def medium_term_score(tech: float, fund: float) -> float:
    """Orta vade: teknik ve temel dengeli (50/50)."""
    return round(tech * 0.5 + fund * 0.5, 1)


def long_term_score(tech: float, fund: float) -> float:
    """Uzun vade: ağırlıklı olarak temel analiz (70/30)."""
    return round(tech * 0.3 + fund * 0.7, 1)

"""Kullanıcının panelden ekleyip çıkarabildiği watchlist (CSV tabanlı)."""
from __future__ import annotations

import os

import pandas as pd

WATCHLIST_PATH = os.path.join("data", "watchlist.csv")
DEFAULT_TICKERS = ["NVDA", "AAPL", "TSLA", "SOFI", "SMCI", "MSFT", "AMD", "META"]


def _ensure_file() -> None:
    os.makedirs(os.path.dirname(WATCHLIST_PATH), exist_ok=True)
    if not os.path.exists(WATCHLIST_PATH):
        pd.DataFrame({"ticker": DEFAULT_TICKERS}).to_csv(WATCHLIST_PATH, index=False)


def load_watchlist() -> list[str]:
    _ensure_file()
    df = pd.read_csv(WATCHLIST_PATH)
    if "ticker" not in df.columns:
        return []
    return [str(t).strip().upper() for t in df["ticker"].dropna().tolist()]


def save_watchlist(tickers: list[str]) -> None:
    os.makedirs(os.path.dirname(WATCHLIST_PATH), exist_ok=True)
    cleaned = sorted({t.strip().upper() for t in tickers if t.strip()})
    pd.DataFrame({"ticker": cleaned}).to_csv(WATCHLIST_PATH, index=False)


def add_ticker(ticker: str) -> list[str]:
    ticker = ticker.strip().upper()
    tickers = load_watchlist()
    if ticker and ticker not in tickers:
        tickers.append(ticker)
        save_watchlist(tickers)
    return tickers


def remove_ticker(ticker: str) -> list[str]:
    ticker = ticker.strip().upper()
    tickers = [t for t in load_watchlist() if t != ticker]
    save_watchlist(tickers)
    return tickers
