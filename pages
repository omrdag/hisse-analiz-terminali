"""Watchlist'e hisse ekleme/çıkarma sayfası."""
from __future__ import annotations

import streamlit as st

from core import watchlist_store

st.set_page_config(page_title="Watchlist Yönetimi", page_icon="📋", layout="wide")
st.title("📋 Watchlist Yönetimi")
st.caption("Fırsat Radarı'nın tarayacağı hisse listesini buradan yönetin.")

tickers = watchlist_store.load_watchlist()

col1, col2 = st.columns([3, 1])
with col1:
    new_ticker = st.text_input("Yeni hisse sembolü ekle (örn. NVDA)", "")
with col2:
    st.write("")
    st.write("")
    if st.button("➕ Ekle", use_container_width=True):
        cleaned = new_ticker.strip().upper()
        if cleaned:
            watchlist_store.add_ticker(cleaned)
            st.success(f"{cleaned} watchlist'e eklendi.")
            st.rerun()
        else:
            st.warning("Lütfen bir hisse sembolü girin.")

st.divider()
st.subheader(f"Mevcut Watchlist ({len(tickers)} hisse)")

if not tickers:
    st.info("Watchlist boş. Yukarıdan hisse ekleyin.")
else:
    for t in tickers:
        c1, c2 = st.columns([4, 1])
        c1.write(f"**{t}**")
        if c2.button("Çıkar", key=f"remove_{t}"):
            watchlist_store.remove_ticker(t)
            st.rerun()

"""Seçilen hisse için detaylı analiz kartı (RSI, EMA/SMA, alım bölgeleri, haberler vb.)."""
from __future__ import annotations

import pandas as pd
import streamlit as st

from core import persistence

st.set_page_config(page_title="Hisse Detayı", page_icon="🔍", layout="wide")
st.title("🔍 Hisse Detayı")
st.caption("Fırsat listesindeki bir hissenin tüm gösterge ve seviyelerini incele.")

opp_df = persistence.load_opportunities()
wait_df = persistence.load_waiting_list()
df = pd.concat([opp_df, wait_df], ignore_index=True)

if df.empty:
    st.info("Henüz tarama yapılmadı. Ana sayfadan 'Taramayı Yenile' ile bir tarama başlatın.")
else:
    tickers = sorted(df["ticker"].unique().tolist())
    selected = st.selectbox("Hisse seçin", tickers)
    rows = df[df["ticker"] == selected]

    for _, row in rows.iterrows():
        with st.container(border=True):
            c1, c2, c3 = st.columns([2, 1, 1])
            c1.subheader(f"{row['ticker']} — {row['name']}")
            c2.metric("Güncel Fiyat", f"${row['price']:.2f}")
            c3.metric(f"{row['vade']} Vade Skoru", f"{row['total_score']:.0f}/100")

            st.markdown(f"**Karar:** {row['decision']}  |  **Durum:** {row['status']}")

            d1, d2, d3, d4 = st.columns(4)
            d1.metric("RSI", f"{row['rsi']:.1f}")
            d2.metric("EMA 20", f"${row['ema20']:.2f}")
            d3.metric("SMA 50", f"${row['sma50']:.2f}")
            d4.metric("SMA 200", f"${row['sma200']:.2f}")

            z1, z2, z3 = st.columns(3)
            z1.write(f"**1. Alım Bölgesi:** {row['buy_zone_1']}")
            z2.write(f"**2. Alım Bölgesi:** {row['buy_zone_2']}")
            z3.write(f"**3. Alım Bölgesi:** {row['buy_zone_3']}")

            r1, r2, r3, r4 = st.columns(4)
            r1.write(f"**Stop-loss:** ${row['stop_loss']:.2f}")
            r2.write(f"**Hedef 1:** ${row['target_1']:.2f}")
            r3.write(f"**Hedef 2:** ${row['target_2']:.2f}")
            r4.write(f"**Risk/Ödül:** 1:{row['risk_reward']:.1f}")

            st.write(f"**Alım bölgesine uzaklık:** %{row['distance_pct']:.2f}")
            st.write(f"**Sektör:** {row.get('sector', '-') or '-'}")
            st.write(f"**Haber/Katalizör Skoru:** {row['news_score']:.0f}/100")

    st.divider()
    st.caption(
        "⚠️ Bu analiz yatırım tavsiyesi değildir; karar vermeden önce kendi risk "
        "profilinizi ve portföy büyüklüğünüzü dikkate almalısınız."
    )

"""Bekleme listesi, kriterleri bozulan hisseler ve tarama geçmişi."""
from __future__ import annotations

import streamlit as st

from core import persistence

st.set_page_config(page_title="Bekleme ve Geçmiş", page_icon="🕒", layout="wide")
st.title("🕒 Bekleme Listesi & Geçmiş")

tab1, tab2, tab3 = st.tabs(["Bekleme Listesi", "Kriterleri Bozulan Hisseler", "Tarama Geçmişi"])

with tab1:
    st.caption(
        "Skoru yeterli olsa da alım bölgesi yakınlığı veya risk/ödül (≥1:2) şartını "
        "sağlamayan hisseler — fırsat listesine değil bu listeye düşer."
    )
    waiting_df = persistence.load_waiting_list()
    if waiting_df.empty:
        st.info("Bekleme listesini görmek için ana sayfadan bir tarama çalıştırın.")
    else:
        st.dataframe(waiting_df, use_container_width=True, hide_index=True)

with tab2:
    st.caption("Daha önce fırsat listesindeyken artık kriterleri sağlamayan hisseler.")
    removed_df = persistence.load_removed()
    if removed_df.empty:
        st.info("Henüz kriterleri bozulan bir hisse kaydedilmedi.")
    else:
        st.dataframe(
            removed_df.sort_values("scan_time", ascending=False),
            use_container_width=True,
            hide_index=True,
        )

with tab3:
    st.caption("Geçmiş tüm taramaların tam kaydı (her tarama için tüm watchlist).")
    history_df = persistence.load_history()
    if history_df.empty:
        st.info("Henüz tarama geçmişi yok.")
    else:
        st.dataframe(
            history_df.sort_values("scan_time", ascending=False),
            use_container_width=True,
            hide_index=True,
        )

st.divider()
st.caption(
    "⚠️ Bu analiz yatırım tavsiyesi değildir; karar vermeden önce kendi risk "
    "profilinizi ve portföy büyüklüğünüzü dikkate almalısınız."
)
